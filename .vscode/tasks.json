{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "test",
      "type": "shell",
      "command": "uv run pytest",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "test: couverture HTML",
      "type": "shell",
      "command": "uv run pytest --cov=src --cov-report=html",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "uv run ruff check src/ tests/",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "format",
      "type": "shell",
      "command": "uv run ruff format src/ tests/",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "type-check",
      "type": "shell",
      "command": "uv run mypy src/",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "check complet",
      "type": "shell",
      "command": "make check",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "docs: serve",
      "type": "shell",
      "command": "uv run mkdocs serve",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "docs: build",
      "type": "shell",
      "command": "uv run mkdocs build",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
